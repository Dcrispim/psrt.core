{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "psrt-gui",
  "outputfilename": "psrt-gui",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "http://localhost:5173",
  "postBuildHooks": {
    "windows/amd64": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/install-chrome.ps1 ${bin}",
    "windows/arm64": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/install-chrome.ps1 ${bin}",
    "darwin/amd64": "bash ../../scripts/install-chrome.sh ${bin}",
    "darwin/arm64": "bash ../../scripts/install-chrome.sh ${bin}",
    "linux/amd64": "bash ../../scripts/install-chrome.sh ${bin}",
    "linux/arm64": "bash ../../scripts/install-chrome.sh ${bin}"
  },
  "author": {
    "name": "psrt",
    "email": ""
  }
}
